# App
APP_NAME=MyApp
DEBUG=false
API_PREFIX=/api/v1

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-or-anon-key

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Google Gmail API
# JSON 文字列または credentials/gmail_credentials.json のパス
GMAIL_CREDENTIALS_PATH={"web":{"client_id":"...","client_secret":"...","redirect_uris":["https://your-app.vercel.app/api/v1/oauth/google/callback"]}}
GMAIL_TOKEN_PATH=credentials/gmail_token.json
GMAIL_USER_EMAIL=
GOOGLE_OAUTH_REDIRECT_URI=https://your-app.vercel.app/api/v1/oauth/google/callback
PUBLIC_BASE_URL=https://your-app.vercel.app

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_USER_ID=

# Vercel Cron
CRON_SECRET=generate-a-long-random-string

# Scheduler (Vercel では false 推奨)
SCHEDULER_ENABLED=false
GMAIL_POLL_INTERVAL_MINUTES=5
